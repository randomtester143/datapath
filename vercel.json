{
  "rewrites": [
    {
      "source": "/raw/:id",
      "destination": "/api/raw/:id"
    },
    {
      "source": "/app.js",
      "destination": "/app.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/:id",
      "destination": "/api/view/:id"
    }
  ]
}